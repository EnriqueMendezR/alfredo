{
    "manifest_version" : 3,
    "version": "1.0.0",
    "name": "Alfredo",
    "permissions": [
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action" : {
        "default_title": "Alfredo"
    },
    "icons": {
        "16": "icon-128.png",
        "32": "icon-128.png",
        "48": "icon-128.png",
        "128": "icon-128.png"
    }
}